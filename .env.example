# ── Database ──────────────────────────────────────
# Local (Unix socket):
DATABASE_URL=host=/var/run/postgresql user=<your-user> dbname=ugyen_academy sslmode=disable
# Remote / Render (auto-provided by Render PostgreSQL):
# DATABASE_URL=postgres://<user>:<password>@<host>:5432/ugyen_academy

# ── Auth ──────────────────────────────────────────
JWT_SECRET=your_super_secret_key_minimum_32_chars_long
JWT_EXPIRE=7d

# ── Server ────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000
# Production: CLIENT_URL=https://ugyen-academy-web.onrender.com

# ── Frontend (set in Render static site env vars) ─
# REACT_APP_API_URL=https://ugyen-academy-api.onrender.com/api
