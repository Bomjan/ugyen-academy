{
  "name": "ugyen-academy",
  "version": "1.0.0",
  "private": true,
  "description": "Ugyen Academy — School Management Platform",
  "scripts": {
    "dev":         "concurrently -n \"frontend,backend\" -c \"cyan,green\" \"npm start --prefix frontend\" \"npm run backend\"",
    "frontend":    "npm start --prefix frontend",
    "backend":     "cd backend && go run .",
    "build":       "npm run build --prefix frontend",
    "seed":        "cd backend && go run ./cmd/seed",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
